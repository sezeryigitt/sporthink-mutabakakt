{
  "name": "sporthink-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Sporthink mutabakat backend API",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "npm run build && node --watch dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:pull": "prisma db pull"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@prisma/client": "6.19.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "jose": "6.2.3",
    "mysql2": "3.15.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "20.19.24",
    "prisma": "6.19.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
